# ====== ОБЯЗАТЕЛЬНО ПОМЕНЯТЬ ======
# Секрет для подписи JWT-токенов. Сгенерировать:
#   Linux/Mac:  openssl rand -hex 32
#   Windows:    powershell -c "[Convert]::ToHexString((1..32 | %% {Get-Random -Max 256}))"
SECRET_KEY=1337Hash#
# ====== Остальное можно не трогать ======
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
API_TOKEN_EXPIRE_DAYS=30

# Rate limiting
LOGIN_ATTEMPT_LIMIT=5
LOGIN_ATTEMPT_PERIOD=300
REQUEST_LIMIT=100
